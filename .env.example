#
# Local frontend values. Keys prefixed with VITE_ are bundled into the browser.
#
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_URL=https://dikigoros.gr
VITE_REQUIRE_LIVE_PAYMENTS=true
VITE_ENABLE_LOCAL_BOOKING_FALLBACK=false

#
# Server-only values. Do not prefix these with VITE_ and do not expose them in client code.
# These must be configured as Supabase Edge Function secrets for deployed functions.
#
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
REQUIRE_LIVE_STRIPE=true
STRIPE_PARTNER_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PARTNER_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_PARTNER_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PARTNER_PREMIUM_ANNUAL_PRICE_ID=price_...

RESEND_API_KEY=re_...
PARTNER_AUTH_FROM_EMAIL="Dikigoros <partners@dikigoros.gr>"
ALLOWED_APP_ORIGINS=https://dikigoros.gr
PAYMENT_RECONCILIATION_SECRET=replace-with-long-random-secret
